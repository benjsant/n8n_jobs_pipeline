---
// CV maître — version ATS STRICTE (1 colonne, texte à plat, aucune grille ni
// tableau, titres standard, police système, puces standard). Parsing ATS maximal.
// Anti-IA : aucun tiret cadratin/demi-cadratin (— –) dans le rendu (nettoyés ci-
// dessous), dates entre parenthèses, séparateurs sobres. DeepSeek ne touche JAMAIS
// ce fichier : il fournit seulement `personalization` (cv_title, summary, mise en
// avant / masquage), jamais d'invention. Même contrat de données que template.astro.
import profile from "./profile.json";
import skillsData from "./skills.json";
import projectsData from "./projects.json";
import experiencesData from "./experiences.json";
import educationData from "./education.json";
import certificationsData from "./certifications.json";
import languagesData from "./languages.json";
import interestsData from "./interests.json";

// Anti-IA : remplace tiret cadratin/demi-cadratin (— –) par un trait d'union
// simple, et le point médian (·) par une virgule.
const clean = (s) => String(s ?? "").replace(/[—–]/g, "-").replace(/\s*·\s*/g, ", ");

// ── Personnalisation (sortie de l'agent) ───────────────────────────────
const { personalization = {} } = Astro.props;
const {
  cv_title: customTitle = "",
  summary: customSummary = "",
  highlight_skills = [],
  highlight_projects = [],
  highlight_experiences = [],
  hidden_sections = [],
} = personalization;
const isHidden = (key) => hidden_sections.includes(key);
const summary = clean(customSummary || profile.summary);
const title = clean(customTitle || profile.title);

function reorder(items, highlights, keyFn) {
  const hi = items.filter((i) => highlights.includes(keyFn(i)));
  const rest = items.filter((i) => !highlights.includes(keyFn(i)));
  return [...hi, ...rest];
}

const projects = reorder(projectsData.projects.filter((p) => p.name), highlight_projects, (p) => p.id).map((p) => ({
  ...p,
  name: clean(p.name),
  period: clean(p.period),
  description: clean(p.description),
  tech: (p.tech || []).map(clean),
}));
const experiences = reorder(
  experiencesData.experiences.filter((e) => e.role || e.company),
  highlight_experiences,
  (e) => e.id,
).map((e) => {
  const bullets = e.bullets || [];
  const stackB = bullets.find((b) => /^stack\s*:/i.test(b));
  return {
    company: clean(e.company),
    role: clean(e.role),
    date: clean(e.date),
    location: clean(e.location),
    tasks: bullets.filter((b) => b !== stackB).map(clean),
    stack: stackB ? clean(stackB.replace(/^stack\s*:\s*/i, "").split(/\s*[·,]\s*/).filter(Boolean).join(", ")) : "",
  };
});
const education = educationData.education.filter((e) => e.degree || e.school);
const certifications = (certificationsData.certifications || []).filter((c) => c.name);
const languages = (languagesData.languages || []).filter((l) => l.name);
const interests = (interestsData.interests || []).filter((i) => i.title)
  .map((i) => ({ title: clean(i.title), description: clean(i.description) }));

const skillRows = skillsData.categories
  .map((cat) => ({
    name: clean(cat.name),
    items: reorder(cat.items.filter((s) => s.name), highlight_skills, (s) => s.name)
      .map((s) => ({ label: clean(s.level ? `${s.name} (${s.level})` : s.name), hl: highlight_skills.includes(s.name) })),
  }))
  .filter((c) => c.items.length > 0);
if (!isHidden("languages") && languages.length) {
  skillRows.push({
    name: "Langues",
    items: languages.map((l) => ({ label: clean(l.level ? `${l.name} (${l.level})` : l.name), hl: false })),
  });
}

// ── Contact (texte à plat, séparateur sobre " | ") ─────────────────────
const strip = (u) => String(u || "").replace(/^https?:\/\/(www\.)?/, "").replace(/\/$/, "");
const contacts = [
  { label: "Email", value: profile.email },
  { label: "Portfolio", value: strip(profile.links?.portfolio) },
  { label: "LinkedIn", value: strip(profile.links?.linkedin) },
  { label: "GitHub", value: strip(profile.links?.github) },
].filter((c) => c.value);

const meta = [];
if (profile.permis) meta.push({ label: "Permis", value: clean(profile.permis) });
if (profile.location || profile.mobility_label) meta.push({ label: "Mobilité", value: clean(profile.location || profile.mobility_label) });
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CV - {profile.name}{title ? ` (${title})` : ""}</title>
  </head>
  <body>
    <article class="cv">
      <header class="head">
        <h1>{profile.name || "[Nom]"}</h1>
        {title && <p class="role">{title}</p>}
        <p class="avail">Disponible, démarrage immédiat</p>
        {!isHidden("summary") && summary && <p class="summary">{summary}</p>}
        <p class="contact">
          {contacts.map((c, i) => (
            <Fragment>{i > 0 ? " | " : ""}{c.label} : {c.value}</Fragment>
          ))}
        </p>
        {meta.length > 0 && (
          <p class="contact">
            {meta.map((d, i) => (
              <Fragment>{i > 0 ? " | " : ""}{d.label} : {d.value}</Fragment>
            ))}
          </p>
        )}
      </header>

      {!isHidden("skills") && skillRows.length > 0 && (
        <section>
          <h2>Compétences</h2>
          {skillRows.map((cat) => (
            <p class="skills">
              <strong>{cat.name} :</strong>{" "}
              {cat.items.map((s, i) => (
                <Fragment>{i > 0 ? ", " : ""}{s.hl ? <strong>{s.label}</strong> : s.label}</Fragment>
              ))}
            </p>
          ))}
        </section>
      )}

      {!isHidden("projects") && projects.length > 0 && (
        <section>
          <h2>Projets réalisés</h2>
          {projects.map((p) => (
            <div class="item">
              <p class="item-head"><strong>{p.name}</strong>{p.period ? ` (${p.period})` : ""}</p>
              {p.tech?.length > 0 && <p class="item-tech">{p.tech.join(", ")}</p>}
              {p.description && <p class="item-desc">{p.description}</p>}
            </div>
          ))}
        </section>
      )}

      {!isHidden("experiences") && experiences.length > 0 && (
        <section>
          <h2>Expérience professionnelle</h2>
          {experiences.map((e) => (
            <div class="item">
              <p class="item-head"><strong>{e.company || e.role}</strong>{e.company && e.role ? `, ${e.role}` : ""}{e.date ? `, ${e.date}` : ""}</p>
              {e.tasks.length > 0 && <ul>{e.tasks.map((t) => <li>{t}</li>)}</ul>}
              {e.stack && <p class="item-tech">Environnement : {e.stack}</p>}
            </div>
          ))}
        </section>
      )}

      {!isHidden("education") && education.length > 0 && (
        <section>
          <h2>Formation</h2>
          {education.map((ed) => (
            <p class="line"><strong>{clean(ed.degree)}</strong>, {clean(ed.school)}{ed.location ? `, ${clean(ed.location)}` : ""}{ed.date ? ` (${clean(ed.date)})` : ""}</p>
          ))}
        </section>
      )}

      {!isHidden("certifications") && certifications.length > 0 && (
        <section>
          <h2>Certifications</h2>
          {certifications.map((c) => (
            <p class="line"><strong>{clean(c.name)}</strong>{c.issuer ? `, ${clean(c.issuer)}` : ""}{c.year ? ` (${clean(c.year)})` : ""}</p>
          ))}
        </section>
      )}

      {!isHidden("interests") && interests.length > 0 && (
        <section>
          <h2>Centres d'intérêt</h2>
          {interests.map((i) => (
            <p class="line"><strong>{i.title}</strong>{i.description ? ` : ${i.description}` : ""}</p>
          ))}
        </section>
      )}
    </article>

    <style is:inline>
      /* CV ATS strict : 1 colonne, texte à plat, police système, couleurs sobres.
         Texte entièrement sélectionnable et linéaire pour un parsing maximal. */
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; background: #fff; }
      .cv {
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, Arial, sans-serif;
        color: #111827; font-size: 12px; line-height: 1.45;
        padding: 9mm 14mm; background: #fff; -webkit-font-smoothing: antialiased;
      }

      .head h1 { font-size: 28px; font-weight: 800; letter-spacing: -0.01em; margin: 0; color: #111827; }
      .role { font-size: 15px; font-weight: 700; color: #3730a3; margin: 3px 0 0; }
      .avail { font-size: 11.5px; color: #374151; margin: 4px 0 0; }
      .summary { font-size: 12px; color: #374151; margin: 6px 0 0; line-height: 1.47; }
      .contact { font-size: 11.5px; color: #374151; margin: 5px 0 0; }

      section { margin-top: 9px; }
      h2 {
        font-size: 13px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em;
        color: #3730a3; border-bottom: 1.5px solid #c7d2fe; padding-bottom: 2px; margin: 0 0 5px;
      }

      .skills { font-size: 12px; margin: 2.5px 0; color: #374151; line-height: 1.45; }
      .skills strong { color: #111827; }

      .item { margin-bottom: 5px; }
      .item-head { font-size: 12.5px; margin: 0; color: #111827; }
      .item-tech { font-size: 11px; color: #4b5563; margin: 1px 0 0; }
      .item-desc { font-size: 11.5px; color: #374151; margin: 1px 0 0; line-height: 1.45; }
      ul { margin: 2px 0; padding-left: 18px; }
      li { font-size: 11.5px; color: #374151; line-height: 1.45; margin: 0; }
      .line { font-size: 12px; color: #374151; margin: 2.5px 0; }
      .line strong { color: #111827; }

      @page { size: A4; margin: 0; }
      @media print {
        *, *::before, *::after { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
        section, .item, .line, li { page-break-inside: avoid; }
      }
    </style>
  </body>
</html>
