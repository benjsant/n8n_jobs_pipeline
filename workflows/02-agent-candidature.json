    {
      "parameters": {
        "jsCode": "// Construit les corps de requête du service de rendu (cf. lib/render-payloads.mjs).\n// On NE FAIT QUE recopier ce que l'agent a produit : aucune invention, aucune\n// reformulation. L'expéditeur de la lettre est complété côté service depuis\n// cv/profile.json (profil réel).\nconst agent = $('Parser sortie agent').first().json;\nconst norm = $('Normaliser entrée').first().json;\nconst application_id = String($('Créer candidature (draft)').first().json.id);\nconst arr = (v) => (Array.isArray(v) ? v : []);\nconst p = (agent.personnalisation_cv && typeof agent.personnalisation_cv === 'object') ? agent.personnalisation_cv : {};\nconst company = String(norm.company ?? '');\nconst lettre = (agent.lettre && typeof agent.lettre === 'object') ? agent.lettre : {};\nconst template = String(lettre.template ?? '');\nconst accroche = String(lettre.accroche ?? '');\nconst subject = String(agent.objet_email ?? '');\nconst body = accroche;\nconst cv_payload = { application_id, personalization: {\n  summary: String(p.summary ?? ''),\n  highlight_skills: arr(p.highlight_skills),\n  highlight_projects: arr(p.highlight_projects),\n  highlight_experiences: arr(p.highlight_experiences),\n  hidden_sections: arr(p.hidden_sections),\n} };\nconst letter_payload = { application_id, company, template, accroche, vars: { poste: String(norm.title ?? '') } };\nreturn [{ json: { application_id, company, subject, body, cv_payload, letter_payload } }];"
      },
      "id": "prep-render",
      "name": "Préparer rendu",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1780,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.RENDER_API_URL }}/cv",
        "sendHeaders": true,
        "headerParameters": {
