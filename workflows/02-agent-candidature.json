        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.cv_payload) }}",
        "options": {
          "timeout": 120000
        }
      },
      "id": "render-cv",
      "name": "Rendu CV (PDF)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1960,
