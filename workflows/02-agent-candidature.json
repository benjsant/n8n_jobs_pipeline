    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE offers SET status = 'applied' WHERE id = $1 RETURNING id, status;",
        "options": {
          "queryReplacement": "={{ $('Normaliser entrée').first().json.offer_id }}"
