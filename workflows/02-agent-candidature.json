        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($('Préparer rendu').first().json.letter_payload) }}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "render-letter",
      "name": "Rendu lettre (PDF)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2140,
        300
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO generated_documents (application_id, cv_path, letter_path) VALUES ($1, NULLIF($2,''), NULLIF($3,'')) RETURNING id;",
        "options": {
          "queryReplacement": "={{ [ $('Préparer rendu').first().json.application_id, $('Rendu CV (PDF)').first().json.cv_path, $('Rendu lettre (PDF)').first().json.letter_path ] }}"
        }
      },
      "id": "insert-documents",
      "name": "Enregistrer documents",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        2320,
        300
      ],
      "credentials": {
        "postgres": {
          "id": "REMPLACER",
          "name": "Postgres job-hunter"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Entrée du workflow 04 (Drive + brouillon Gmail). Reprend les chemins PDF.\n// to_email laissé vide : le destinataire est renseigné à la main avant envoi\n// (GARDE-FOU : 04 crée un BROUILLON, jamais d'envoi automatique).\nconst prep = $('Préparer rendu').first().json;\nreturn [{ json: {\n  company: prep.company,\n  cv_path: $('Rendu CV (PDF)').first().json.cv_path,\n  letter_path: $('Rendu lettre (PDF)').first().json.letter_path,\n  to_email: '',\n  subject: prep.subject,\n  body: prep.body,\n} }];"
      },
      "id": "prep-final",
      "name": "Préparer finalisation",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2660,
        200
      ]
    },
    {
      "parameters": {
        "workflowId": {
          "__rl": true,
          "mode": "list",
          "value": "wf04finalisatio",
          "cachedResultName": "04 - Finalisation candidature (Drive + brouillon Gmail)"
        },
        "options": {
          "waitForSubWorkflow": false
        }
      },
      "id": "launch-04",
      "name": "Lancer finalisation (04)",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.2,
      "position": [
        2840,
        200
      ]
    }
