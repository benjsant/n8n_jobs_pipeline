      "typeVersion": 1,
      "position": [
        360,
        460
      ]
    },
    {
      "parameters": {
        "fileSelector": "/prompts/agent-system-prompt.md",
        "options": {}
      },
      "id": "read-prompt",
      "name": "Lire system prompt",
      "type": "n8n-nodes-base.readWriteFile",
      "typeVersion": 1,
      "position": [
        540,
        300
      ]
    },
    {
      "parameters": {
        "operation": "text",
        "sourceProperty": "data",
        "options": {}
      },
      "id": "extract-prompt",
      "name": "Extraire texte prompt",
      "type": "n8n-nodes-base.extractFromFile",
      "typeVersion": 1,
      "position": [
        460,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.DEEPSEEK_BASE_URL }}/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.DEEPSEEK_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"{{ $env.DEEPSEEK_MODEL }}\",\n  \"messages\": [\n    { \"role\": \"system\", \"content\": {{ JSON.stringify($json.data) }} },\n    { \"role\": \"user\", \"content\": {{ JSON.stringify('Offre: ' + $('Normaliser entrée').first().json.title + ' chez ' + $('Normaliser entrée').first().json.company + '\\n\\nDescription:\\n' + $('Normaliser entrée').first().json.description + '\\n\\nInfos entreprise:\\n' + ($('Normaliser entrée').first().json.company_info || 'Non fournies') + '\\n\\nVALEURS DISPONIBLES POUR personnalisation_cv (choisis EXCLUSIVEMENT parmi elles, ids/noms exacts):\\n' + $('Extraire index CV').first().json.data) }} }\n  ],\n  \"response_format\": { \"type\": \"json_object\" },\n  \"temperature\": 0.7\n}",
        "options": {}
      },
      "id": "call-deepseek",
      "name": "Appel DeepSeek",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Parse la sortie de l'agent et la valide a minima (cf. system prompt §6).\nconst raw = $input.first().json.choices?.[0]?.message?.content ?? '';\nlet p;\ntry { p = JSON.parse(raw); } catch (e) { p = { erreur: 'JSON invalide', brut: raw }; }\nif (typeof p.score !== 'number') p.score = 0;\nif (!p.lettre || typeof p.lettre !== 'object') p.lettre = { template: '', accroche: '' };\nif (!p.personnalisation_cv || typeof p.personnalisation_cv !== 'object') {\n  p.personnalisation_cv = { summary: '', highlight_skills: [], highlight_projects: [], highlight_experiences: [], hidden_sections: [] };\n}\nreturn [{ json: p }];"
      },
      "id": "parse-output",
      "name": "Parser sortie agent",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "version": 2
          },
          "combinator": "and",
          "conditions": [
            {
              "leftValue": "={{ String($('Normaliser entrée').first().json.offer_id ?? '') }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty",
                "singleValue": true
              }
            }
          ]
        },
        "options": {}
      },
      "id": "if-offer",
      "name": "Offre liée ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        1120,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Enrichissement GROUNDED (cf. lib/company-enrichment.mjs) : résumé entreprise\n// UNIQUEMENT à partir du texte réel de l'offre. N'invente rien.\nconst company = $('Normaliser entrée').first().json.company || '';\nconst src = (($('Normaliser entrée').first().json.company_info || '') + '\\n' + ($('Normaliser entrée').first().json.description || '')).slice(0, 2000);\nconst system = \"Tu produis une fiche entreprise SYNTHÉTIQUE à partir UNIQUEMENT du texte fourni. Tu n'inventes RIEN : si une information n'est pas présente, tu laisses \\\"\\\". Tu réponds UNIQUEMENT en JSON {\\\"sector\\\":\\\"\\\",\\\"ai_summary\\\":\\\"\\\"}. ai_summary : 1-2 phrases neutres.\";\nconst user = `ENTREPRISE: ${company || '(inconnue)'}\\n\\nTEXTE SOURCE (ne te sers QUE de ça):\\n${src}`;\nreturn [{ json: { messages: [{role:'system',content:system},{role:'user',content:user}] } }];"
      },
      "id": "prep-enrich",
      "name": "Préparer enrichissement",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        120
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.DEEPSEEK_BASE_URL }}/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.DEEPSEEK_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"{{ $env.DEEPSEEK_MODEL }}\",\n  \"messages\": {{ JSON.stringify($json.messages) }},\n  \"response_format\": { \"type\": \"json_object\" },\n  \"temperature\": 0.2\n}",
        "options": {}
      },
      "id": "call-enrich",
      "name": "DeepSeek entreprise",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1480,
        120
      ]
    },
    {
      "parameters": {
        "jsCode": "// Parse la fiche entreprise (cf. parseEnrichmentResponse). Champs vides si KO.\nconst raw = $input.first().json.choices?.[0]?.message?.content ?? '';\nlet d; try { d = JSON.parse(raw); } catch { d = null; }\nreturn [{ json: { sector: String(d?.sector ?? '').trim(), ai_summary: String(d?.ai_summary ?? '').trim() } }];"
      },
      "id": "parse-enrich",
      "name": "Parser entreprise",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1660,
        120
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO companies (name, sector, ai_summary, last_updated) VALUES ($1, NULLIF($2,''), NULLIF($3,''), now()) ON CONFLICT (name) DO UPDATE SET sector = COALESCE(NULLIF(EXCLUDED.sector,''), companies.sector), ai_summary = COALESCE(NULLIF(EXCLUDED.ai_summary,''), companies.ai_summary), last_updated = now() RETURNING id;",
        "options": {
          "queryReplacement": "={{ [$('Normaliser entrée').first().json.company, $json.sector, $json.ai_summary] }}"
        }
      },
      "id": "upsert-company",
      "name": "Upsert entreprise",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        1840,
        120
      ],
      "credentials": {
        "postgres": {
          "id": "REMPLACER",
          "name": "Postgres job-hunter"
        }
      }
    },
    {
      "parameters": {
        "operation": "insert",
        "schema": {
          "__rl": true,
          "mode": "list",
          "value": "public"
        },
        "table": {
          "__rl": true,
          "mode": "list",
          "value": "applications"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "offer_id": "={{ $('Normaliser entrée').first().json.offer_id }}",
            "company_id": "={{ $('Upsert entreprise').first().json.id }}",
            "status": "draft",
            "notes": "={{ 'score ' + $('Parser sortie agent').first().json.score + ' — ' + ($('Parser sortie agent').first().json.justification_score || '') }}"
          }
        },
        "options": {}
      },
      "id": "insert-application",
      "name": "Créer candidature (draft)",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
