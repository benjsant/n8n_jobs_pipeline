        "assignments": {
          "assignments": [
            { "id": "k1", "name": "keywords", "value": "développeur intelligence artificielle", "type": "string" },
            { "id": "k2", "name": "location", "value": "France", "type": "string" },
            { "id": "k3", "name": "ftCommune", "value": "", "type": "string" },
