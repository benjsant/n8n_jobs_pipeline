    {
      "parameters": {
        "operation": "insert",
        "schema": { "__rl": true, "mode": "list", "value": "public" },
        "table": { "__rl": true, "mode": "list", "value": "offers" },
        "columns": { "mappingMode": "defineBelow", "value": {
          "source": "={{ $json.source }}", "source_id": "={{ $json.source_id }}",
          "hash": "={{ $json.hash }}", "title": "={{ $json.title }}",
          "company": "={{ $json.company }}", "location": "={{ $json.location }}",
          "contract_type": "={{ $json.contract_type }}", "salary": "={{ $json.salary }}",
          "description": "={{ $json.description }}", "url": "={{ $json.url }}",
          "score": "={{ $json.score }}", "profile_id": "={{ $json.profile_id }}"
        } },
        "options": { "skipOnConflict": true }
      },
      "id": "a1000000-0000-4000-8000-000000000053",
      "name": "Insert offers (dédup)",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1560, 360],
      "credentials": { "postgres": { "id": "REMPLACER", "name": "Postgres job-hunter" } }
    },
    {
      "parameters": { "jsCode": "// Affinage LLM du top-N avec must_have/exclusions DU PROFIL (cf. llm-scoring.mjs).\nconst prof=$('Boucle profils').item.json;\nconst all=$input.all().map(i=>i.json);\nconst offers=[...all].sort((a,b)=>(b.score??0)-(a.score??0)).slice(0,20);\nconst system=\"Tu es un expert en recrutement. Barème: 90-100 = correspond très bien aux critères indispensables et aucune exclusion; 50-89 = partiel; <50 = hors sujet ou exclusion. Réponds UNIQUEMENT en JSON {\\\"scores\\\":[{\\\"i\\\":<index>,\\\"score\\\":<0-100>,\\\"reason\\\":\\\"<une phrase>\\\"}]}.\";\nconst list=offers.map((o,i)=>`#${i} — ${o.title||'?'} @ ${o.company||'?'} (${o.location||'?'})\\n${String(o.description||'').slice(0,600)}`).join('\\n\\n');\nconst user=`Critères indispensables : ${prof.must_have||'(non précisés)'}\\nCritères d'exclusion : ${prof.exclusions||'(aucun)'}\\n\\nOFFRES:\\n${list}`;\nreturn [{json:{messages:[{role:'system',content:system},{role:'user',content:user}],offers,threshold:prof.score_threshold||60}}];" },
      "id": "a1000000-0000-4000-8000-000000000056",
      "name": "Préparer scoring LLM",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1780, 360]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.DEEPSEEK_BASE_URL }}/chat/completions",
        "sendHeaders": true,
        "headerParameters": { "parameters": [
          { "name": "Authorization", "value": "=Bearer {{ $env.DEEPSEEK_API_KEY }}" },
          { "name": "Content-Type", "value": "application/json" }
        ] },
        "sendBody": true, "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"{{ $env.DEEPSEEK_MODEL }}\",\n  \"messages\": {{ JSON.stringify($json.messages) }},\n  \"response_format\": { \"type\": \"json_object\" },\n  \"temperature\": 0.2\n}",
        "options": {}
      },
      "id": "a1000000-0000-4000-8000-000000000057",
      "name": "DeepSeek scoring",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2000, 360]
    },
    {
      "parameters": { "jsCode": "const clamp=(n)=>Math.max(0,Math.min(100,Math.round(Number(n)||0)));\nconst raw=$input.first().json.choices?.[0]?.message?.content??'';\nconst offers=$('Préparer scoring LLM').first().json.offers||[];\nlet data;try{data=JSON.parse(raw);}catch{data=null;}\nconst byI=new Map();for(const s of (data?.scores??[]))if(Number.isInteger(s.i))byI.set(s.i,s);\nreturn offers.map((o,i)=>{const s=byI.get(i);return{json:(!s||s.score==null)?o:{...o,score:clamp(s.score),score_reason:String(s.reason??'')}};});" },
      "id": "a1000000-0000-4000-8000-000000000058",
      "name": "Fusion scores",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2220, 360]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE offers SET score = $1, score_reason = $2 WHERE hash = $3;",
        "options": { "queryReplacement": "={{ [$json.score, $json.score_reason || '', $json.hash] }}" }
      },
      "id": "a1000000-0000-4000-8000-000000000059",
      "name": "MAJ score (LLM)",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [2440, 360],
      "credentials": { "postgres": { "id": "REMPLACER", "name": "Postgres job-hunter" } }
