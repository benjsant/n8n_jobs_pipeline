    {
      "parameters": { "jsCode": "// Score piloté par le PROFIL + exclusions (filtre dur) + hashSource canonicalisé.\n// Parité avec workflows/lib/offer-utils.mjs.\nconst prof=$('Boucle profils').item.json;\nconst norm=(s)=>String(s??'').toLowerCase().normalize('NFKD').replace(/\\s+/g,' ').trim();\nconst cT=(t)=>norm(t).replace(/\\(.*?\\)/g,' ').replace(/\\b[hf]\\s*\\/\\s*[hfx]\\b/g,' ').replace(/\\bf\\s*\\/\\s*h\\b/g,' ').replace(/[^a-z0-9àâäéèêëîïôöùûüç ]/g,' ').replace(/\\s+/g,' ').trim();\nconst cC=(c)=>norm(c).replace(/\\b(sas|sasu|sarl|sa|eurl|inc|ltd|llc|gmbh|group|groupe)\\b/g,' ').replace(/[^a-z0-9àâäéèêëîïôöùûüç ]/g,' ').replace(/\\s+/g,' ').trim();\nconst cL=(l)=>norm(l).replace(/\\bfrance\\b/g,' ').replace(/[^a-zàâäéèêëîïôöùûüç ]/g,' ').replace(/\\s+/g,' ').trim();\nconst DEF={keywords:['ia','intelligence artificielle','ml','machine learning','data','llm','python','développeur','developpeur','backend','api'],juniorTerms:['junior','débutant','debutant','alternance','apprenti','stage','stagiaire','entry level'],seniorTerms:['senior','confirmé','confirme','lead','principal','5 ans','expérimenté','experimente','10 ans'],remoteTerms:['télétravail','teletravail','remote','hybride','distanciel'],goodContracts:['cdi','alternance','cdd','apprentissage','freelance']};\nconst sw=(s)=>norm(s).split(/[,;\\n\\s]+/).filter(Boolean);\nconst sp=(s)=>String(s??'').split(/[,;\\n]+/).map(norm).filter(Boolean);\nconst kw=[...sw(prof.keywords),...sp(prof.must_have)];\nconst ct=sp(prof.contract_types);\nconst P={keywords:kw.length?kw:DEF.keywords,exclusions:sp(prof.exclusions),contractTypes:ct.length?ct:DEF.goodContracts,seniority:norm(prof.seniority)};\nfunction sen(hay){const j=DEF.juniorTerms.some(t=>hay.includes(norm(t)));const se=DEF.seniorTerms.some(t=>hay.includes(norm(t)));const w=P.seniority;if(/junior|alternance|débutant|debutant|apprenti|stage/.test(w)){if(j&&!se)return 20;return se?0:10;}if(/senior|confirm|lead|expérim|experim/.test(w)){if(se&&!j)return 20;return j?5:10;}return se&&!j?5:12;}\nfunction score(o){const hay=norm(`${o.title} ${o.description} ${o.contract_type}`);const loc=norm(o.location);let s=0;s+=Math.min(40,P.keywords.filter(k=>hay.includes(norm(k))).length*10);s+=sen(hay);if(DEF.remoteTerms.some(t=>hay.includes(norm(t))||loc.includes(norm(t))))s+=15;if(P.contractTypes.some(c=>hay.includes(norm(c))||norm(o.contract_type).includes(norm(c))))s+=15;if(norm(o.salary))s+=10;return Math.max(0,Math.min(100,Math.round(s)));}\nfunction exc(o){if(!P.exclusions.length)return false;const hay=norm(`${o.title} ${o.description} ${o.contract_type} ${o.location}`);return P.exclusions.some(x=>x&&hay.includes(norm(x)));}\nreturn $input.all().map(({json:o})=>o).filter(o=>!exc(o)).map((o)=>({json:{...o,score:score(o),profile_id:prof.id,hashSource:[cT(o.title),cC(o.company),cL(o.location)].join('|')}}));" },
      "id": "a1000000-0000-4000-8000-000000000051",
      "name": "Scorer + hashSource",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 360]
    },
    {
      "parameters": { "action": "hash", "type": "SHA256", "value": "={{ $json.hashSource }}", "dataPropertyName": "hash", "options": {} },
