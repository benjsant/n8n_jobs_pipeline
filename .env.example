# =====================================================================
#  job-hunter — variables d'environnement (TEMPLATE)
#  Copie ce fichier en .env et remplis les valeurs.
#  NE JAMAIS committer le vrai .env (il est dans .gitignore).
# =====================================================================

# ---------- PostgreSQL (persistance des workflows n8n) ----------
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_moi_mot_de_passe_solide
POSTGRES_DB=n8n

# ---------- Ports publiés vers l'hôte ----------
# Interface d'écoute : 127.0.0.1 = local uniquement (recommandé ; la mini-interface
# n'a pas d'authentification). Mets 0.0.0.0 pour ouvrir au réseau local, ou l'IP
# WireGuard sur un VPS.
BIND_HOST=127.0.0.1
# Ports internes des conteneurs inchangés ; seuls ces ports d'accès local
# changent. Si tu modifies N8N_PORT, aligne WEBHOOK_URL sur le même port.
N8N_PORT=8978
UI_PORT=8901
METABASE_PORT=8930

# ---------- n8n : accès et chiffrement ----------
# Génère une clé : openssl rand -hex 32
N8N_ENCRYPTION_KEY=remplace_par_une_cle_de_32_octets_hex
N8N_HOST=localhost
WEBHOOK_URL=http://localhost:8978/
# Identifiants pour se connecter à l'interface n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_moi_aussi

# ---------- DeepSeek (LLM de l'agent) ----------
# Récupère ta clé sur https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
# deepseek-chat (rapide, généraliste) ou deepseek-reasoner (raisonnement)
DEEPSEEK_MODEL=deepseek-chat

# ---------- Notion (OPTIONNEL — consultation seule, hors V1) ----------
# La source de vérité est PostgreSQL. Notion n'est plus le stockage ; ne le
# configurer que si tu veux une vue de consultation par-dessus la base.
# Intégration interne : https://www.notion.so/profile/integrations
NOTION_API_KEY=
NOTION_DB_OFFRES=
NOTION_DB_ENTREPRISES=

# ---------- Google (Gmail brouillon + Drive archivage) ----------
# L'authentification se fait via les credentials OAuth du nœud Google dans n8n
# (pas une clé en clair ici). Gmail = brouillon UNIQUEMENT, jamais d'envoi auto.
# Dossier Drive cible : Candidatures/<Entreprise>/
GOOGLE_DRIVE_FOLDER=Candidatures

# ---------- France Travail (API offres d'emploi) ----------
# https://francetravail.io — crée une application pour obtenir les credentials
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# ---------- Adzuna (API agrégateur d'offres) ----------
# https://developer.adzuna.com — crée une app gratuite (app_id + app_key)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ---------- JobSpy (micro-service Python, mis en place en Tâche 6) ----------
# URL interne du service JobSpy (conteneur séparé)
JOBSPY_API_URL=http://jobspy:8000

# ---------- Service de rendu (CV Astro + lettre -> PDF, micro-service Node) ----------
# URL interne du service de rendu (conteneur séparé). PDF écrits dans ./output.
RENDER_API_URL=http://render:8000
# Style du CV généré : "ats" (défaut, 1 colonne sans photo, pensé filtres ATS)
# ou "design" (hero indigo, timeline, photo optionnelle via cv/public/photo.jpg).
CV_STYLE=ats

# ---------- Agent de candidature (LangGraph, micro-service Python) ----------
# URL interne du service agent (conteneur séparé). Le workflow 02 y poste l'offre
# au lieu d'appeler DeepSeek en direct. Le service lit lui-même le prompt + l'index CV.
AGENT_API_URL=http://agent-langgraph:8001

# ---------- Embeddings (dédup sémantique, micro-service fastembed) ----------
# URL interne du service d'embeddings. Le workflow 01 y poste le texte d'une offre
# pour obtenir un vecteur (stocké dans offers.embedding, pgvector) et repérer les
# quasi-doublons inter-sources. Aucune clé (modèle local embarqué dans l'image).
EMBEDDINGS_API_URL=http://embeddings:8002

# ---------- Rétention des candidatures locales (./output) ----------
# Le service "cleanup" supprime les dossiers app-* de ./output au-delà de N jours.
# Les PDF durables sont archivés sur Google Drive (workflow 04) ; ./output n'est
# qu'un dossier de travail. Mets 14 (2 sem.) ou 21 (3 sem.) selon ta préférence.
OUTPUT_RETENTION_DAYS=21

# ---------- Welcome to the Jungle (RSS) ----------
# Pas de clé ; l'URL du flux RSS se règle dans le workflow (ou ici, optionnel)
WTTJ_RSS_URL=

# ---------- Google Jobs via SerpApi (source principale du pipeline réel) ----------
# https://serpapi.com — crée un compte, récupère la clé API
SERPAPI_KEY=

# ---------- JSearch via RapidAPI (agrégateur LinkedIn/Indeed/Glassdoor, API) ----------
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch — souscris (offre gratuite),
# récupère la clé X-RapidAPI-Key. Alternative fiable au scraping JobSpy.
RAPIDAPI_KEY=

# ---------- La Bonne Alternance (offres alternance + entreprises à contacter) ----------
# Service public apprentissage / beta.gouv. Espace développeurs :
# https://api.apprentissage.beta.gouv.fr → clé API. Cherche par codes ROME +
# lat/long (cf. colonnes latitude/longitude/rome_codes de search_profiles).
LBA_API_KEY=

# ---------- Discord (notifications) — deux canaux ----------
# Salon Discord → Paramètres → Intégrations → Webhooks → Nouveau webhook
# Crée DEUX webhooks (deux salons) :
#   - ALERTS : offres pertinentes (actionnables)
#   - LOG    : logs techniques (nb récupérées / doublons / retenues)
DISCORD_WEBHOOK_ALERTS=
DISCORD_WEBHOOK_LOG=
# Alias rétro-compatible (= ALERTS si tu n'as qu'un seul webhook). Optionnel.
DISCORD_WEBHOOK_URL=

# ---------- Airtable (historique des candidatures, optionnel) ----------
# Miroir d'historique quand tu marques une offre « Postulé » dans l'interface.
# Postgres reste la source de vérité ; Airtable n'est qu'une vue.
#   AIRTABLE_TOKEN : jeton personnel (https://airtable.com/create/tokens),
#                      scope data.records:write sur ta base.
#   AIRTABLE_BASE_ID : id de la base (commence par app…, visible dans l'URL/API).
#   Table « Candidatures » avec colonnes : Poste, Entreprise, Lieu, Lien (url),
#   Score (number), Statut (text), Date (date).
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE=Candidatures
