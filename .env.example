# =====================================================================
#  job-hunter — variables d'environnement (TEMPLATE)
#  Copie ce fichier en .env et remplis les valeurs.
#  NE JAMAIS committer le vrai .env (il est dans .gitignore).
# =====================================================================

# ---------- PostgreSQL (persistance des workflows n8n) ----------
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_moi_mot_de_passe_solide
POSTGRES_DB=n8n

# ---------- n8n : accès et chiffrement ----------
# Génère une clé : openssl rand -hex 32
N8N_ENCRYPTION_KEY=remplace_par_une_cle_de_32_octets_hex
N8N_HOST=localhost
WEBHOOK_URL=http://localhost:5678/
# Identifiants pour se connecter à l'interface n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_moi_aussi

# ---------- DeepSeek (LLM de l'agent) ----------
# Récupère ta clé sur https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
# deepseek-chat (rapide, généraliste) ou deepseek-reasoner (raisonnement)
DEEPSEEK_MODEL=deepseek-chat

# ---------- Notion (suivi des candidatures) ----------
# Crée une intégration interne : https://www.notion.so/profile/integrations
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_OFFRES=id_de_ta_base_offres
NOTION_DB_ENTREPRISES=id_de_ta_base_entreprises

# ---------- France Travail (API offres d'emploi) ----------
# https://francetravail.io — crée une application pour obtenir les credentials
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# ---------- Telegram (notifications) ----------
# Crée un bot via @BotFather, récupère le token et ton chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
